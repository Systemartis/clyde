root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs by convention; gofmt will rewrite anything else, so the editor
# should match.
[*.go]
indent_style = tab
indent_size = 8

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
