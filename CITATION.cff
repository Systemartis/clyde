cff-version: 1.2.0
title: "clyde — terminal companion for Claude Code"
message: "If you use clyde in research or tooling, please cite it as below."
type: software
authors:
  - name: Systemartis
    website: "https://systemartis.com"
  - family-names: Popescu-Bejat
